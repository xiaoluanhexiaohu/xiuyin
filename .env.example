# Authentication / web jobs
XIUYIN_ADMIN_USERNAME=admin
# sha256$... hash; do not store plaintext passwords in production
XIUYIN_ADMIN_PASSWORD_HASH=sha256$CHANGE_ME
XIUYIN_JWT_SECRET=change-me
XIUYIN_WEB_JOBS_DIR=outputs/web_jobs
XIUYIN_QUEUE_MODE=inline
XIUYIN_REDIS_URL=redis://localhost:6379/0

# Licensed/reference metadata providers
JAMENDO_CLIENT_ID=
FREESOUND_API_KEY=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
YOUTUBE_API_KEY=
